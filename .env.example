# ============================================================
# S&G Entertainment Studio Booking — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# ── App ──────────────────────────────────────────────────────
# Production: https://sngent.com
# Development: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://sngent.com
NODE_ENV=production

# ── Database (Supabase / PostgreSQL) ─────────────────────────
# Get from https://supabase.com → Project → Settings → Database → Connection String
DATABASE_URL="postgresql://user:password@host:5432/sg_studio_booking"

# ── Hubtel Payment Gateway ────────────────────────────────────
# Environment: "sandbox" (default) or "production"
# Defaults to sandbox for safety - only set to "production" when ready for live payments
HUBTEL_ENV=sandbox

# Sandbox credentials (for testing - get from Hubtel developer portal)
# TODO: set via Vercel dashboard / .env.local
HUBTEL_SANDBOX_API_ID=your_sandbox_api_id_here
HUBTEL_SANDBOX_API_KEY=your_sandbox_api_key_here
HUBTEL_SANDBOX_MERCHANT_ACCOUNT_NUMBER=your_sandbox_merchant_account_here

# Production credentials (for live payments - only use when HUBTEL_ENV=production)
# TODO: set via Vercel dashboard / .env.local
HUBTEL_API_ID=your_production_api_id_here
HUBTEL_API_KEY=your_production_api_key_here
HUBTEL_MERCHANT_ACCOUNT_NUMBER=your_production_merchant_account_here

# Webhook secret for verifying Hubtel payment callbacks
HUBTEL_WEBHOOK_SECRET=your_hubtel_webhook_secret_here

# Hubtel callback URL (where Hubtel sends payment notifications)
# Must be publicly accessible - use your production domain
# TODO: set via Vercel dashboard / .env.local
HUBTEL_CALLBACK_URL=https://sngent.com/api/hubtel/webhook

# ── WhatsApp (Twilio API for WhatsApp) ───────────────────────
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Twilio WhatsApp sender (sandbox: whatsapp:+14155238886 | production: your approved number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Studio owner's WhatsApp number (Ghana: +233XXXXXXXXX)
STUDIO_OWNER_WHATSAPP=whatsapp:+233XXXXXXXXX
# Studio owner's email for fallback notifications
STUDIO_OWNER_EMAIL=info@sgentertainment.com.gh

# ── Studio Config ────────────────────────────────────────────
NEXT_PUBLIC_STUDIO_NAME="S&G Entertainment"
NEXT_PUBLIC_STUDIO_LOCATION="Taifa, Accra, Ghana"
NEXT_PUBLIC_STUDIO_PHONE="+233 XX XXX XXXX"
NEXT_PUBLIC_STUDIO_EMAIL="info@sgentertainment.com.gh"
# Session rate in GHS (Ghana Cedis) — GHS 300 for first 2h30m, then +60 per 30min
NEXT_PUBLIC_HOURLY_RATE=300
# Minimum booking duration in hours (2.5 = 2h 30m)
NEXT_PUBLIC_MIN_HOURS=2.5
# Maximum booking duration in hours
NEXT_PUBLIC_MAX_HOURS=12
# Booking lead time in hours (how far in advance must a booking be made)
NEXT_PUBLIC_BOOKING_LEAD_HOURS=2

# ── Admin Panel Authentication (Supabase) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
