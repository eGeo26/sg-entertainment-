# ============================================================
# S&G Entertainment Studio Booking — Environment Variables
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database (PostgreSQL on Railway / Supabase / Render) ─────
DATABASE_URL="postgresql://user:password@host:5432/sg_studio_booking"

# ── Anolla Booking Engine ────────────────────────────────────
# Get these from your Anolla provider dashboard → Settings → Integrations → API
ANOLLA_API_KEY=your_anolla_api_key_here
ANOLLA_PROVIDER_ID=your_anolla_provider_id_here
ANOLLA_WIDGET_ID=your_anolla_widget_id_here
# Base URL for Anolla REST API (check your dashboard for region)
ANOLLA_API_BASE_URL=https://api.anolla.com/v1
# Webhook secret for verifying Anolla webhooks
ANOLLA_WEBHOOK_SECRET=your_anolla_webhook_secret_here
# Studio/resource ID within Anolla (the recording room)
ANOLLA_RESOURCE_ID=your_studio_resource_id_here

# ── Paystack ─────────────────────────────────────────────────
# Get from https://dashboard.paystack.com → Settings → API Keys & Webhooks
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Set this in Paystack dashboard → Settings → API Keys & Webhooks → Webhook URL
# Value: https://your-domain.com/api/paystack/webhook
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret_here

# ── WhatsApp (Twilio API for WhatsApp) ───────────────────────
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Twilio WhatsApp sender (sandbox: whatsapp:+14155238886 | production: your approved number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Studio owner's WhatsApp number (Ghana: +233XXXXXXXXX)
STUDIO_OWNER_WHATSAPP=whatsapp:+233XXXXXXXXX
# Studio owner's email for fallback notifications
STUDIO_OWNER_EMAIL=info@sgentertainment.com.gh

# ── Studio Config ────────────────────────────────────────────
NEXT_PUBLIC_STUDIO_NAME="S&G Entertainment"
NEXT_PUBLIC_STUDIO_LOCATION="Taifa, Accra, Ghana"
NEXT_PUBLIC_STUDIO_PHONE="+233 XX XXX XXXX"
NEXT_PUBLIC_STUDIO_EMAIL="info@sgentertainment.com.gh"
# Hourly rate in GHS (Ghana Cedis)
NEXT_PUBLIC_HOURLY_RATE=200
# Minimum booking duration in hours
NEXT_PUBLIC_MIN_HOURS=2
# Maximum booking duration in hours
NEXT_PUBLIC_MAX_HOURS=12
# Booking lead time in hours (how far in advance must a booking be made)
NEXT_PUBLIC_BOOKING_LEAD_HOURS=2

# ── Optional: AfricasTalking (alternative WhatsApp / SMS for Ghana) ─
# Get from https://africastalking.com
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=your_africas_talking_username
